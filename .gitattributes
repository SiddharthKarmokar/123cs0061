# Force all text files to use LF (Unix) line endings on check-in
* text=auto

# Denote specific files as binary to prevent line-ending conversion
*.jpg binary
*.png binary

# Track large files using Git LFS
*.psd filter=lfs diff=lfs merge=lfs -text

# Exclude specific files from the archive (zip/tar)
/tests export-ignore
.gitignore export-ignore
